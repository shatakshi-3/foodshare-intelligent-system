<main class="d-flex">
  <%- include('../partials/adminSidebar') %>

  <div id="main-wrapper" class="flex-grow-1">
    <div class="bg-white shadow-sm p-3 d-flex align-items-center justify-content-between">
      <div class="d-flex align-items-center">
        <span class="me-3" id="sidebar-toggler-btn"><i class="fas fa-bars"></i></span>
        <h5 class="m-0 text-primary">Recipients</h5>
      </div>
      <a href="/admin/recipient/add" class="btn btn-primary btn-sm">+ Add Recipient</a>
    </div>

    <div class="container my-4">
      <% if (recipients.length === 0) { %>
        <div class="alert alert-info">No recipients registered yet. Add one to get started.</div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-hover bg-white shadow-sm rounded">
            <thead class="table-dark">
              <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Location</th>
                <th>Contact</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% recipients.forEach(r => { %>
                <tr class="<%= r.isActive ? '' : 'table-secondary' %>">
                  <td><%= r.name %></td>
                  <td><span class="badge bg-info text-capitalize"><%= r.type.replace('_', ' ') %></span></td>
                  <td><%= r.location %></td>
                  <td><%= r.contactName %> (<%= r.contactPhone %>)</td>
                  <td>
                    <span class="badge bg-<%= r.isActive ? 'success' : 'secondary' %>">
                      <%= r.isActive ? 'Active' : 'Inactive' %>
                    </span>
                  </td>
                  <td>
                    <a href="/admin/recipient/view/<%= r._id %>" class="btn btn-sm btn-outline-primary">View</a>
                    <a href="/admin/recipient/toggle/<%= r._id %>" class="btn btn-sm btn-outline-<%= r.isActive ? 'warning' : 'success' %>">
                      <%= r.isActive ? 'Deactivate' : 'Activate' %>
                    </a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</main>
