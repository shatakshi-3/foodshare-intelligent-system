<main class="d-flex">
  <%- include('../partials/adminSidebar') %>

  <div id="main-wrapper" class="flex-grow-1">
    <div class="bg-white shadow-sm p-3 d-flex align-items-center">
      <span class="me-3" id="sidebar-toggler-btn"><i class="fas fa-bars"></i></span>
      <h5 class="m-0 text-primary">Recipient Details</h5>
    </div>

    <div class="container my-4">
      <div class="card shadow-sm border-0 rounded-3 p-4">
        <div class="row g-3">
          <div class="col-md-6">
            <strong>Name:</strong> <span><%= recipient.name %></span>
          </div>
          <div class="col-md-6">
            <strong>Type:</strong>
            <span class="badge bg-info text-capitalize"><%= recipient.type.replace('_', ' ') %></span>
          </div>
          <div class="col-md-12">
            <strong>Location:</strong> <span><%= recipient.location %></span>
          </div>

          <hr>

          <div class="col-md-4">
            <strong>Contact Person:</strong> <span><%= recipient.contactName %></span>
          </div>
          <div class="col-md-4">
            <strong>Email:</strong> <span><%= recipient.contactEmail %></span>
          </div>
          <div class="col-md-4">
            <strong>Phone:</strong> <span><%= recipient.contactPhone %></span>
          </div>

          <div class="col-md-6">
            <strong>Status:</strong>
            <span class="badge bg-<%= recipient.isActive ? 'success' : 'secondary' %>">
              <%= recipient.isActive ? 'Active' : 'Inactive' %>
            </span>
          </div>
          <div class="col-md-6">
            <strong>Registered:</strong>
            <span><%= recipient.createdAt.toLocaleString("en-IN", { dateStyle: "medium", timeStyle: "short" }) %></span>
          </div>
        </div>

        <div class="mt-4 text-center">
          <a href="/admin/recipient/edit/<%= recipient._id %>" class="btn btn-primary me-2">Edit</a>
          <a href="/admin/recipient/toggle/<%= recipient._id %>" class="btn btn-outline-<%= recipient.isActive ? 'warning' : 'success' %>">
            <%= recipient.isActive ? 'Deactivate' : 'Activate' %>
          </a>
          <a href="/admin/recipients" class="btn btn-outline-secondary ms-2">Back to List</a>
        </div>
      </div>
    </div>
  </div>
</main>
