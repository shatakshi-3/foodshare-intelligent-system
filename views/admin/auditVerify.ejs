<main class="d-flex">
  <%- include('../partials/adminSidebar') %>

  <div id="main-wrapper" class="flex-grow-1">
    <div class="bg-white shadow-sm p-3 d-flex align-items-center">
      <span class="me-3" id="sidebar-toggler-btn"><i class="fas fa-bars"></i></span>
      <h5 class="m-0 text-primary"><i class="fas fa-shield-alt me-2"></i>Chain Integrity Verification</h5>
    </div>

    <div class="container my-4">

      <!-- Summary Card -->
      <div class="card shadow-sm border-0 mb-4 border-start border-4 border-<%= result.allValid ? 'success' : 'danger' %>">
        <div class="card-body text-center py-4">
          <% if (result.allValid) { %>
            <h2 class="text-success"><i class="fas fa-check-circle me-2"></i>Chain Integrity Verified</h2>
            <p class="text-muted mb-0">All <%= result.total %> log entries passed SHA-256 hash verification.</p>
          <% } else { %>
            <h2 class="text-danger"><i class="fas fa-exclamation-triangle me-2"></i>Chain Integrity Compromised</h2>
            <p class="text-danger mb-0"><%= result.invalidCount %> of <%= result.total %> entries failed verification.</p>
          <% } %>
        </div>
      </div>

      <!-- Verification Results Table -->
      <% if (result.results.length > 0) { %>
        <div class="table-responsive">
          <table class="table table-sm bg-white shadow-sm rounded">
            <thead class="table-dark">
              <tr>
                <th>Entry</th>
                <th>Action</th>
                <th>Time</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% result.results.forEach((r, i) => { %>
                <tr class="<%= r.valid ? '' : 'table-danger' %>">
                  <td><%= i + 1 %></td>
                  <td class="text-capitalize"><%= r.action.replace(/_/g, ' ') %></td>
                  <td class="small"><%= new Date(r.createdAt).toLocaleString("en-IN", { dateStyle: "short", timeStyle: "medium" }) %></td>
                  <td>
                    <% if (r.valid) { %>
                      <span class="badge bg-success"><i class="fas fa-check"></i> Valid</span>
                    <% } else { %>
                      <span class="badge bg-danger"><i class="fas fa-times"></i> TAMPERED</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="alert alert-info">No audit log entries to verify.</div>
      <% } %>

      <div class="text-center mt-4">
        <a href="/admin/audit" class="btn btn-outline-primary">Back to Audit Logs</a>
      </div>
    </div>
  </div>
</main>
