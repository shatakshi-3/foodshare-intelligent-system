<main class="d-flex">
  <%- include('../partials/adminSidebar') %>

  <div id="main-wrapper" class="flex-grow-1">
    <div class="bg-white shadow-sm p-3 d-flex align-items-center">
      <span class="me-3" id="sidebar-toggler-btn"><i class="fas fa-bars"></i></span>
      <h5 class="m-0 text-primary">Edit Recipient</h5>
    </div>

    <div class="container my-4">
      <form action="/admin/recipient/edit/<%= recipient._id %>" method="POST" class="card shadow border-0 p-4">

        <div class="row">
          <div class="mb-3 col-md-6">
            <label for="name" class="form-label">Organization Name</label>
            <input type="text" name="recipient[name]" class="form-control" id="name" value="<%= recipient.name %>" required>
          </div>
          <div class="mb-3 col-md-6">
            <label for="type" class="form-label">Type</label>
            <select name="recipient[type]" id="type" class="form-select" required>
              <option value="ngo" <%= recipient.type === 'ngo' ? 'selected' : '' %>>NGO</option>
              <option value="shelter" <%= recipient.type === 'shelter' ? 'selected' : '' %>>Shelter</option>
              <option value="community_kitchen" <%= recipient.type === 'community_kitchen' ? 'selected' : '' %>>Community Kitchen</option>
              <option value="orphanage" <%= recipient.type === 'orphanage' ? 'selected' : '' %>>Orphanage</option>
              <option value="other" <%= recipient.type === 'other' ? 'selected' : '' %>>Other</option>
            </select>
          </div>
        </div>

        <div class="mb-3">
          <label for="location" class="form-label">Location / Address</label>
          <input type="text" name="recipient[location]" class="form-control" id="location" value="<%= recipient.location %>" required>
        </div>

        <hr class="my-3">
        <h6 class="text-secondary mb-3">Contact Information</h6>

        <div class="row">
          <div class="mb-3 col-md-4">
            <label for="contactName" class="form-label">Contact Person</label>
            <input type="text" name="recipient[contactName]" class="form-control" id="contactName" value="<%= recipient.contactName %>" required>
          </div>
          <div class="mb-3 col-md-4">
            <label for="contactEmail" class="form-label">Contact Email</label>
            <input type="email" name="recipient[contactEmail]" class="form-control" id="contactEmail" value="<%= recipient.contactEmail %>" required>
          </div>
          <div class="mb-3 col-md-4">
            <label for="contactPhone" class="form-label">Contact Phone</label>
            <input type="tel" name="recipient[contactPhone]" class="form-control" id="contactPhone" value="<%= recipient.contactPhone %>" required pattern="[0-9]{10}">
          </div>
        </div>

        <div class="text-center mt-3">
          <button type="submit" class="btn btn-primary w-50">Update Recipient</button>
        </div>
      </form>
    </div>
  </div>
</main>
