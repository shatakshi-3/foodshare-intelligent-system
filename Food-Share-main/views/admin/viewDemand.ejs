<main class="d-flex">
  <%- include('../partials/adminSidebar') %>

  <div id="main-wrapper" class="flex-grow-1">
    <div class="bg-white shadow-sm p-3 d-flex align-items-center">
      <span class="me-3" id="sidebar-toggler-btn"><i class="fas fa-bars"></i></span>
      <h5 class="m-0 text-primary">Demand Details</h5>
    </div>

    <div class="container my-4">
      <div class="card shadow-sm border-0 rounded-3 p-4">
        <div class="row g-3">
          <div class="col-md-6">
            <strong>Recipient:</strong>
            <span>
              <% if (demand.recipient) { %>
                <a href="/admin/recipient/view/<%= demand.recipient._id %>"><%= demand.recipient.name %></a>
              <% } else { %>
                N/A
              <% } %>
            </span>
          </div>
          <div class="col-md-6">
            <strong>Urgency:</strong>
            <span class="badge bg-<%= demand.urgency === 'high' ? 'danger' : demand.urgency === 'medium' ? 'warning' : 'success' %>">
              <%= demand.urgency %>
            </span>
          </div>
          <div class="col-md-6">
            <strong>Food Type:</strong> <span><%= demand.foodType %></span>
          </div>
          <div class="col-md-6">
            <strong>Quantity Needed:</strong> <span><%= demand.quantityNeeded %></span>
          </div>
          <div class="col-md-6">
            <strong>Quantity Fulfilled:</strong> <span><%= demand.quantityFulfilled %></span>
          </div>
          <div class="col-md-6">
            <strong>Status:</strong>
            <span class="badge bg-<%= demand.status === 'open' ? 'primary' : demand.status === 'partially_fulfilled' ? 'info' : demand.status === 'fulfilled' ? 'success' : 'secondary' %> text-capitalize">
              <%= demand.status.replace('_', ' ') %>
            </span>
          </div>
          <div class="col-md-12">
            <strong>Delivery Location:</strong> <span><%= demand.location %></span>
          </div>

          <% if (demand.notes) { %>
            <div class="col-12">
              <strong>Notes:</strong>
              <div class="alert alert-info mt-2"><%= demand.notes %></div>
            </div>
          <% } %>

          <div class="col-md-6">
            <strong>Created:</strong>
            <span><%= demand.createdAt.toLocaleString("en-IN", { dateStyle: "medium", timeStyle: "short" }) %></span>
          </div>
        </div>

        <hr class="my-3">

        <div class="d-flex justify-content-center gap-2 flex-wrap">
          <% if (demand.status === "open" || demand.status === "partially_fulfilled") { %>
            <form action="/admin/demand/status/<%= demand._id %>" method="POST" class="d-inline">
              <input type="hidden" name="status" value="fulfilled">
              <button type="submit" class="btn btn-success btn-sm">Mark Fulfilled</button>
            </form>
            <form action="/admin/demand/status/<%= demand._id %>" method="POST" class="d-inline">
              <input type="hidden" name="status" value="expired">
              <button type="submit" class="btn btn-outline-secondary btn-sm">Mark Expired</button>
            </form>
          <% } %>
          <a href="/admin/demand/delete/<%= demand._id %>" class="btn btn-outline-danger btn-sm"
             onclick="return confirm('Are you sure you want to delete this demand?')">Delete</a>
          <a href="/admin/demands" class="btn btn-outline-secondary btn-sm">Back to List</a>
        </div>
      </div>
    </div>
  </div>
</main>
