<main class="d-flex">
  <%- include('../partials/adminSidebar') %>

  <div id="main-wrapper" class="flex-grow-1">
    <div class="bg-white shadow-sm p-3 d-flex align-items-center justify-content-between">
      <div class="d-flex align-items-center">
        <span class="me-3" id="sidebar-toggler-btn"><i class="fas fa-bars"></i></span>
        <h5 class="m-0 text-primary"><i class="fas fa-history me-2"></i>Audit Logs</h5>
      </div>
      <a href="/admin/audit/verify" class="btn btn-outline-success btn-sm">
        <i class="fas fa-shield-alt me-1"></i>Verify Chain Integrity
      </a>
    </div>

    <div class="container my-4">

      <!-- Filters -->
      <form method="GET" action="/admin/audit" class="card shadow-sm border-0 p-3 mb-4">
        <div class="row g-2 align-items-end">
          <div class="col-md-4">
            <label class="form-label small fw-bold">Action Type</label>
            <select name="action" class="form-select form-select-sm">
              <option value="">All Actions</option>
              <% actionTypes.forEach(a => { %>
                <option value="<%= a %>" <%= filters.action === a ? 'selected' : '' %>><%= a.replace(/_/g, ' ') %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label small fw-bold">Target Model</label>
            <select name="targetModel" class="form-select form-select-sm">
              <option value="">All Models</option>
              <% ["donation", "user", "recipient", "demand", "match"].forEach(m => { %>
                <option value="<%= m %>" <%= filters.targetModel === m ? 'selected' : '' %>><%= m %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-primary btn-sm w-100">Filter</button>
          </div>
          <div class="col-md-2">
            <a href="/admin/audit" class="btn btn-outline-secondary btn-sm w-100">Reset</a>
          </div>
        </div>
      </form>

      <!-- Log Table -->
      <% if (logs.length === 0) { %>
        <div class="alert alert-info">No audit logs found matching the filters.</div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-hover bg-white shadow-sm rounded">
            <thead class="table-dark">
              <tr>
                <th>Time</th>
                <th>Action</th>
                <th>User</th>
                <th>Target</th>
                <th>Hash</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% logs.forEach(log => { %>
                <%
                  let actionColor = 'secondary';
                  if (log.action.includes('created') || log.action.includes('registered')) actionColor = 'success';
                  else if (log.action.includes('rejected') || log.action.includes('deleted')) actionColor = 'danger';
                  else if (log.action.includes('accepted') || log.action.includes('collected')) actionColor = 'primary';
                  else if (log.action.includes('assigned') || log.action.includes('updated')) actionColor = 'info';
                  else if (log.action.includes('match') || log.action.includes('llm')) actionColor = 'warning';
                %>
                <tr>
                  <td class="small text-nowrap"><%= new Date(log.createdAt).toLocaleString("en-IN", { dateStyle: "short", timeStyle: "medium" }) %></td>
                  <td><span class="badge bg-<%= actionColor %> text-capitalize"><%= log.action.replace(/_/g, ' ') %></span></td>
                  <td class="small">
                    <% if (log.performedBy) { %>
                      <%= log.performedBy.firstName %> <%= log.performedBy.lastName %>
                      <span class="text-muted">(<%= log.performedBy.role %>)</span>
                    <% } else { %>
                      <span class="text-muted">System</span>
                    <% } %>
                  </td>
                  <td class="small">
                    <% if (log.targetModel) { %>
                      <span class="text-capitalize"><%= log.targetModel %></span>
                    <% } %>
                  </td>
                  <td class="small text-muted font-monospace"><%= log.hash.substring(0, 12) %>...</td>
                  <td><a href="/admin/audit/view/<%= log._id %>" class="btn btn-sm btn-outline-primary">Detail</a></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
          <nav class="d-flex justify-content-center mt-3">
            <ul class="pagination pagination-sm">
              <% for (let i = 1; i <= totalPages; i++) { %>
                <li class="page-item <%= page === i ? 'active' : '' %>">
                  <a class="page-link" href="/admin/audit?page=<%= i %>&action=<%= filters.action %>&targetModel=<%= filters.targetModel %>"><%= i %></a>
                </li>
              <% } %>
            </ul>
          </nav>
        <% } %>

        <div class="text-muted small text-center mt-2">
          Showing page <%= page %> of <%= totalPages %> (<%= total %> total entries)
        </div>
      <% } %>

    </div>
  </div>
</main>
